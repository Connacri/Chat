rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // User Profiles
    match /users/{userId} {
      // Allow read for anyone to enable discovery
      allow read: if true;
      // Allow write only for the owner
      // In a real P2P, we use DIDs, here we check the ID in the document
      allow create: if true;
      allow update: if true; // In production, should check if request.auth.uid == userId if using Firebase Auth for all
    }

    // WebRTC Signaling
    match /signals/{signalId} {
      allow create: if true;
      allow read: if true; // Receiver must read it
      allow delete: if true; // Cleanup after receipt
    }

    // Presence Registry
    match /presence/{nodeId} {
      allow read, write: if true;
    }
  }
}
